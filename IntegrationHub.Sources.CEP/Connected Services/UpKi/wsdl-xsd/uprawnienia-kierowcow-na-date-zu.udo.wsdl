<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns="http://schemas.xmlsoap.org/wsdl/"
             xmlns:xsd="http://www.w3.org/2001/XMLSchema"
             xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
             xmlns:upki="http://uprawnieniakierowcow-na-date-zu.tru.api.cepik.coi.gov.pl"
             xmlns:ex="http://exceptions.api.cepik.coi.gov.pl"
             targetNamespace="http://uprawnieniakierowcow-na-date-zu.tru.api.cepik.coi.gov.pl">
    <xsd:annotation>
        <xsd:documentation>
            Uprawnienia Kierowców Udostępnianie Na Datę ZU
            Version: 1.0.1
        </xsd:documentation>
    </xsd:annotation>

    <types>
        <schema xmlns="http://www.w3.org/2001/XMLSchema"
                targetNamespace="http://uprawnieniakierowcow-na-date-zu.tru.api.cepik.coi.gov.pl">
            <include schemaLocation="uprawnienia-kierowcow-na-date-zu.udo.xsd"/>
            <import namespace="http://exceptions.api.cepik.coi.gov.pl" schemaLocation="exceptions/exceptions.xsd"/>
        </schema>
    </types>

    <message name="DaneDokumentuRequest">
        <part element="upki:DaneDokumentuRequest" name="DaneDokumentuRequest"/>
    </message>

    <message name="DaneDokumentuResponse">
        <part element="upki:DaneDokumentuResponse" name="DaneDokumentuResponse"/>
    </message>

    <message name="DaneDokumentuException">
        <part element="ex:cepikException" name="DaneDokumentuError"/>
    </message>

    <portType name="UprawnieniaKierowcowNaDateZuUdoWS">
        <operation name="pytanieOUprawnieniaNaDateZU">
            <input message="upki:DaneDokumentuRequest" name="DaneDokumentuRequest"/>
            <output message="upki:DaneDokumentuResponse" name="DaneDokumentuResponse"/>
            <fault message="upki:DaneDokumentuException" name="DaneDokumentuException"/>
        </operation>
    </portType>

    <binding name="UprawnieniaKierowcowNaDateZuUdoSoapBinding" type="upki:UprawnieniaKierowcowNaDateZuUdoWS">
        <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
        <operation name="pytanieOUprawnieniaNaDateZU">
            <soap:operation soapAction=""/>
            <input>
                <soap:body use="literal"/>
            </input>
            <output>
                <soap:body use="literal"/>
            </output>
            <fault name="DaneDokumentuException">
                <soap:fault name="DaneDokumentuException" use="literal"/>
            </fault>
        </operation>
    </binding>

    <service name="UprawnieniaKierowcowNaDateZuUdoWebService">
        <port binding="upki:UprawnieniaKierowcowNaDateZuUdoSoapBinding" name="UprawnieniaKierowcowNaDateZuUdoSoapPort">
            <soap:address location=""/>
        </port>
    </service>

</definitions>
