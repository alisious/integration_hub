{
  "AuditLogging": {
    "Enabled": true,
    "CompressBodies": true,
    "StoreBodies": true,
    "MaxBodyBytes": 524288, // 512 KB przycięcia
    "Redaction": {
      "Enabled": true,
      "Patterns": [
        "(?<pesel>\\b\\d{11}\\b)",
        "(?<vin>\\b[A-HJ-NPR-Z0-9]{17}\\b)"
      ],
      "Replacement": "***"
    },
    "Sql": {
      "ConnectionString": "Server=20.100.30.9;Database=IntegrationHubDB;User Id=SA;Password=1234qwerASDF;TrustServerCertificate=True;",
      "BatchSize": 50,
      "FlushIntervalMs": 1000
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=20.100.30.9;Database=PIESP_DB;User Id=SA;Password=1234qwerASDF;TrustServerCertificate=True;Encrypt=True",
    "IntegrationHubDB": "Server=20.100.30.9;Database=IntegrationHubDB;User Id=SA;Password=1234qwerASDF;TrustServerCertificate=True;"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {TraceId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
